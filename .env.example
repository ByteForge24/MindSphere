# === MindSphere Docker Configuration ===
# Copy this file to .env and fill in the values

# MongoDB
MONGO_USER=mindsphere
MONGO_PASSWORD=change_me_in_production

# Backend
JWT_SECRET=change_me_to_a_long_random_string
GEMINI_API_KEY=your_gemini_api_key_here
SENTRY_DSN=
LOG_LEVEL=info

# Base URL of the backend (used to build absolute OAuth callback URLs behind reverse proxies)
BASE_URL=http://localhost:5000

# OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback
FRONTEND_URL=http://localhost:80

# Frontend (build-time)
VITE_API_URL=http://localhost:5000/api
VITE_BACKEND_URL=http://localhost:5000
